# ============================================
# BINANCE API CONFIGURATION
# ============================================
# For TESTNET: Use testnet API keys and set BINANCE_BASE_URL
# For PRODUCTION: Use production API keys and LEAVE BINANCE_BASE_URL EMPTY
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_BASE_URL=https://testnet.binancefuture.com

# ============================================
# GEMINI AI CONFIGURATION
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# TRADING CONFIGURATION
# ============================================
TRADING_SYMBOL=BTCUSDT

# Risk Management (CRITICAL - Adjust based on your risk tolerance)
RISK_PER_TRADE=0.01              # 1% risk per trade (conservative)
MAX_DAILY_LOSS_PERCENT=0.03      # Stop trading if lose 3% in a day
LEVERAGE=5                        # 5x leverage (moderate risk)
MAX_POSITION_SIZE=0.5            # Max 50% of balance per position

# Technical Analysis Settings
TIMEFRAME=5m                      # Primary trading timeframe
HIGHER_TIMEFRAME=1h              # Trend confirmation timeframe
USE_HIGHER_TIMEFRAME=true        # Enable trend filter (recommended)
ATR_PERIOD=14                    # ATR period for volatility

# ============================================
# TELEGRAM NOTIFICATIONS (Highly Recommended)
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============================================
# NOTES FOR PRODUCTION
# ============================================
# 1. Start with small capital ($100-500) for testing
# 2. Monitor for 1-2 weeks before scaling up
# 3. Never risk more than you can afford to lose
# 4. Keep leverage moderate (3-5x recommended)
# 5. Enable Telegram notifications for monitoring
# 6. Review logs daily in /logs folder
